DATABASE_URL="postgresql://stok_user:stok_password@localhost:5432/stok_db"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="your_super_secret_jwt_key_change_in_production"
PORT=3000
NODE_ENV=development

# Twilio (OTP via SMS) - optional for production
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Anthropic AI for agent functionality
ANTHROPIC_API_KEY=your_anthropic_api_key

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS
FRONTEND_URL=http://localhost:3001

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
# Set to true to always use "123456" as OTP in development
DEV_OTP_BYPASS=true
